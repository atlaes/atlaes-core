# Database Configuration
DATABASE_URL=postgresql://vbl_user:vbl_password@localhost:5432/vbl_development
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# AWS Configuration (for SST)
AWS_PROFILE=atlaes
AWS_REGION=eu-central-1
AWS_DEFAULT_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=your-aws-access-key  # Use AWS_PROFILE instead
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key  # Use AWS_PROFILE instead

# Third-party Services (for future phases)
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SendGrid
SENDGRID_API_KEY=SG...

# AWS S3 (for document storage)
AWS_S3_BUCKET=vbl-documents-eu-central-1
AWS_S3_REGION=eu-central-1

# Mistral AI (for GPR/RPT platforms)
MISTRAL_API_KEY=...

# Wise API (for GPR platform)
WISE_API_TOKEN=...

# Lettershop API (for VBL/DIY platforms)
LETTERSHOP_API_KEY=...
LETTERSHOP_BASE_URL=https://api.lettershop.de
