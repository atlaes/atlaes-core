{
  "name": "@vbl/functions",
  "version": "1.0.0",
  "description": "Hono backend functions for VBL platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "sst:dev": "sst dev",
    "sst:deploy": "sst deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push:pg",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.5",
    "drizzle-orm": "^0.29.0",
    "hono": "^4.0.0",
    "postgres": "^3.4.3",
    "redis": "^4.6.10",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/pg": "^8.10.9",
    "drizzle-kit": "^0.20.4",
    "sst": "^3.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
