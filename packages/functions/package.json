{
  "name": "@vbl/functions",
  "version": "1.0.0",
  "description": "Hono backend functions for VBL platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "node build.js",
    "build:tsc": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "sst:dev": "AWS_PROFILE=atlaes sst dev",
    "sst:deploy": "AWS_PROFILE=atlaes sst deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push:pg",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ses": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hono/node-server": "^1.19.5",
    "@hono/zod-validator": "^0.7.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.29.0",
    "google-auth-library": "^10.4.2",
    "hono": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "mindee": "4.36.0",
    "pg": "^8.16.3",
    "postgres": "^3.4.3",
    "redis": "^4.6.10",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "drizzle-kit": "^0.20.4",
    "esbuild": "^0.19.0",
    "sst": "^3.19.3",
    "supertest": "^7.1.4",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16"
  }
}
